{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "stls",
  "version": "0.1.0",
  "identifier": "net.soheilroko.stls",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "stls - ShadowTLS Client",
        "width": 600,
        "height": 700,
        "minWidth": 500,
        "minHeight": 600,
        "resizable": true,
        "visible": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "stls - ShadowTLS Client"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}