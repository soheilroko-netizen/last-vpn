{
  "$schema": "../node_modules/@tauri-apps/schemas/config-schemas.json",
  "identifier": "default",
  "description": "Capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-minimize",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "store:default",
    "dialog:default",
    "fs:default",
    "notification:default",
    "opener:default",
    "os:default",
    "shell:default"
  ]
}
