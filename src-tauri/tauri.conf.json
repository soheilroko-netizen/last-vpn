{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "stls",
  "version": "5.0.0",
  "identifier": "com.stls.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "resources": ["bin/sing-box.exe"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "admin"
      }
    }
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  }
}
